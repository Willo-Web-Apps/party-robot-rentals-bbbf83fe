---
const year = new Date().getFullYear();
---
<footer style="background: oklch(0.07 0.02 280); border-top: 1px solid oklch(0.60 0.26 10 / 0.20);">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-14">

    <div class="grid md:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-lg" style="background: oklch(0.60 0.26 10 / 0.18); border: 1px solid oklch(0.60 0.26 10 / 0.5);">
            🤖
          </div>
          <span class="font-display text-xl" style="color: oklch(0.95 0.005 280);">
            Robo<span style="color: oklch(0.60 0.26 10);">Fête</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs" style="color: oklch(0.55 0.01 280); font-family: var(--font-body);">
          The premier robot rental experience for parties and events. LED and humanoid robots for birthdays, weddings, quinceañeras, and corporate events.
        </p>
        <div class="flex gap-3 mt-5">
          <!-- Social icons -->
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200 hover:opacity-80" style="background: oklch(0.12 0.025 280); border: 1px solid oklch(0.20 0.025 280);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: oklch(0.62 0.01 280);"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200 hover:opacity-80" style="background: oklch(0.12 0.025 280); border: 1px solid oklch(0.20 0.025 280);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: oklch(0.62 0.01 280);"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07Z"/></svg>
          </a>
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200 hover:opacity-80" style="background: oklch(0.12 0.025 280); border: 1px solid oklch(0.20 0.025 280);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: oklch(0.62 0.01 280);"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-display text-sm mb-4" style="color: oklch(0.95 0.005 280);">Services</h4>
        <ul class="space-y-2.5" style="font-family: var(--font-body);">
          {['LED Dancer Robot', 'Humanoid Host', 'Premium Duo Show', 'Corporate Events', 'Weddings', 'Quinceañeras'].map(item => (
            <li><a href="#packages" class="text-sm transition-colors duration-150" style="color: oklch(0.55 0.01 280);" onmouseover="this.style.color='oklch(0.82 0.14 10)'" onmouseout="this.style.color='oklch(0.55 0.01 280)'">{item}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-display text-sm mb-4" style="color: oklch(0.95 0.005 280);">Company</h4>
        <ul class="space-y-2.5" style="font-family: var(--font-body);">
          {[
            { label: 'How It Works', href: '#how-it-works' },
            { label: 'Packages & Pricing', href: '#packages' },
            { label: 'Blog', href: '/blog' },
            { label: 'Contact Us', href: 'mailto:hello@robofete.com' },
          ].map(item => (
            <li><a href={item.href} class="text-sm transition-colors duration-150" style="color: oklch(0.55 0.01 280);" onmouseover="this.style.color='oklch(0.82 0.14 10)'" onmouseout="this.style.color='oklch(0.55 0.01 280)'">{item.label}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid oklch(0.16 0.025 280);" class="pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-sm" style="color: oklch(0.40 0.01 280); font-family: var(--font-body);">
        &copy; {year} RoboFête. All rights reserved. The Future of Unforgettable Parties.
      </p>
      <div class="flex gap-6" style="font-family: var(--font-body);">
        <a href="#" class="text-sm transition-colors duration-150" style="color: oklch(0.40 0.01 280);" onmouseover="this.style.color='oklch(0.65 0.01 280)'" onmouseout="this.style.color='oklch(0.40 0.01 280)'">Privacy Policy</a>
        <a href="#" class="text-sm transition-colors duration-150" style="color: oklch(0.40 0.01 280);" onmouseover="this.style.color='oklch(0.65 0.01 280)'" onmouseout="this.style.color='oklch(0.40 0.01 280)'">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>
