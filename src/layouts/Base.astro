---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "RoboFête — Robot Rentals for Unforgettable Parties & Events", description = "Rent jaw-dropping LED and humanoid robots for birthdays, quinceañeras, weddings, and corporate events. Instant quotes, transparent pricing, guaranteed wow factor." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "RoboFête",
      "description": "Premier robot rental experience for parties and events — LED and humanoid robots for birthdays, quinceañeras, weddings, and corporate events.",
      "url": "https://party-robot-rentals.onrender.com",
      "telephone": "+18005550199",
      "email": "hello@robofete.com",
      "slogan": "The Future of Unforgettable Parties",
      "areaServed": "United States"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background: oklch(0.09 0.02 280); color: oklch(0.95 0.005 280);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
