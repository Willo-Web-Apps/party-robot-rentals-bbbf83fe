---
import Base from '../layouts/Base.astro';
---
<Base
  title="RoboFête — Robot Rentals for Unforgettable Parties & Events"
  description="Rent jaw-dropping LED and humanoid robots for birthdays, quinceañeras, weddings, and corporate events. Instant quotes, transparent pricing, guaranteed wow factor."
>

  <!-- =====================================================================
       HERO
       ===================================================================== -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background: oklch(0.09 0.02 280);">

    <!-- Layered gradient background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <!-- Primary glow — rose, top-left offset -->
      <div style="
        position: absolute;
        width: 70vw; height: 70vw;
        top: -20%; left: -15%;
        background: radial-gradient(ellipse at center, oklch(0.60 0.26 10 / 0.22) 0%, transparent 65%);
        filter: blur(8px);
      "></div>
      <!-- Secondary glow — gold, bottom-right -->
      <div style="
        position: absolute;
        width: 55vw; height: 55vw;
        bottom: -25%; right: -10%;
        background: radial-gradient(ellipse at center, oklch(0.87 0.20 88 / 0.18) 0%, transparent 65%);
        filter: blur(12px);
      "></div>
      <!-- Cyan accent — mid-right -->
      <div style="
        position: absolute;
        width: 35vw; height: 35vw;
        top: 35%; right: 5%;
        background: radial-gradient(ellipse at center, oklch(0.72 0.18 200 / 0.12) 0%, transparent 65%);
        filter: blur(10px);
      "></div>
      <!-- Noise texture overlay -->
      <div style="
        position: absolute; inset: 0;
        background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E&quot;);
        opacity: 0.035;
        mix-blend-mode: overlay;
      "></div>
    </div>

    <div class="relative w-full max-w-7xl mx-auto px-6 lg:px-10 py-24 md:py-32 lg:py-40 grid lg:grid-cols-2 gap-12 lg:gap-0 items-center">

      <!-- Left: Text -->
      <div class="relative z-10">
        <!-- Badge -->
        <div class="animate-slide-up inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-full text-xs font-semibold tracking-widest uppercase" style="
          background: oklch(0.60 0.26 10 / 0.14);
          border: 1px solid oklch(0.60 0.26 10 / 0.50);
          color: oklch(0.82 0.14 10);
        ">
          <span style="display:inline-block; width:7px; height:7px; border-radius:50%; background: oklch(0.60 0.26 10); box-shadow: 0 0 8px 2px oklch(0.60 0.26 10 / 0.8);"></span>
          Now Booking · Summer 2025
        </div>

        <!-- Headline -->
        <h1 class="animate-slide-up delay-100 font-display leading-[0.95] tracking-tight" style="font-size: clamp(2.8rem, 7vw, 5.5rem); color: oklch(0.95 0.005 280);">
          Your Party Just Got<br>
          <span class="gradient-text">a Futuristic Upgrade</span>
        </h1>

        <!-- Sub -->
        <p class="animate-slide-up delay-200 mt-7 text-lg md:text-xl leading-relaxed max-w-xl" style="color: oklch(0.78 0.01 280);">
          Rent a jaw-dropping LED or humanoid robot that dances, poses, and creates electric moments your guests will talk about for years.
        </p>

        <!-- CTA row -->
        <div class="animate-slide-up delay-300 mt-10 flex flex-wrap items-center gap-4">
          <a
            href="#packages"
            class="animate-pulse-glow inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg text-white transition-all duration-200 hover:scale-105"
            style="background: oklch(0.60 0.26 10); font-family: var(--font-body);"
          >
            See Robot Packages
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-4 rounded-xl font-medium text-base transition-all duration-200 hover:opacity-80" style="color: oklch(0.78 0.01 280); border: 1px solid oklch(0.78 0.01 280 / 0.3);">
            How it works
          </a>
        </div>

        <!-- Micro-proof -->
        <div class="animate-fade-in delay-400 mt-10 flex flex-wrap items-center gap-6">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-2">
              <!-- Avatar placeholders -->
              <div class="w-8 h-8 rounded-full border-2 flex items-center justify-center text-xs font-bold" style="border-color: oklch(0.09 0.02 280); background: oklch(0.60 0.26 10);">J</div>
              <div class="w-8 h-8 rounded-full border-2 flex items-center justify-center text-xs font-bold" style="border-color: oklch(0.09 0.02 280); background: oklch(0.87 0.20 88); color: oklch(0.09 0.02 280);">M</div>
              <div class="w-8 h-8 rounded-full border-2 flex items-center justify-center text-xs font-bold" style="border-color: oklch(0.09 0.02 280); background: oklch(0.72 0.18 200);">A</div>
            </div>
            <span class="text-sm" style="color: oklch(0.70 0.01 280);">
              <strong style="color: oklch(0.87 0.20 88);">500+</strong> events electrified
            </span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14" style="color: oklch(0.87 0.20 88);"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z" clip-rule="evenodd"/></svg>
              ))}
            </div>
            <span class="text-sm" style="color: oklch(0.70 0.01 280);">4.9 average rating</span>
          </div>
        </div>
      </div>

      <!-- Right: Visual element — glowing robot display -->
      <div class="relative flex items-center justify-center lg:justify-end" aria-hidden="true">
        <!-- Floating orb behind -->
        <div class="animate-float-orb absolute" style="
          width: min(480px, 85vw); height: min(480px, 85vw);
          border-radius: 50%;
          background: radial-gradient(ellipse at 40% 40%,
            oklch(0.60 0.26 10 / 0.28) 0%,
            oklch(0.87 0.20 88 / 0.12) 45%,
            transparent 70%
          );
          filter: blur(4px);
        "></div>

        <!-- Robot silhouette card -->
        <div class="relative z-10 rounded-2xl overflow-hidden" style="
          width: min(360px, 78vw);
          aspect-ratio: 3/4;
          background: linear-gradient(160deg,
            oklch(0.14 0.025 280) 0%,
            oklch(0.11 0.02 280) 60%,
            oklch(0.10 0.025 10) 100%
          );
          border: 1px solid oklch(0.60 0.26 10 / 0.35);
          box-shadow: 0 0 0 1px oklch(0.60 0.26 10 / 0.15),
                      0 32px 64px -16px oklch(0.09 0.02 280),
                      inset 0 1px 0 oklch(0.95 0.005 280 / 0.06);
        ">
          <!-- Decorative grid lines -->
          <div style="
            position:absolute; inset:0;
            background-image: linear-gradient(oklch(0.60 0.26 10 / 0.07) 1px, transparent 1px),
                              linear-gradient(90deg, oklch(0.60 0.26 10 / 0.07) 1px, transparent 1px);
            background-size: 32px 32px;
          "></div>

          <!-- Robot "figure" built from pure CSS shapes -->
          <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;">
            <!-- Head -->
            <div style="
              width:80px; height:72px; border-radius:18px;
              background: linear-gradient(160deg, oklch(0.22 0.04 280), oklch(0.15 0.03 280));
              border: 1.5px solid oklch(0.60 0.26 10 / 0.6);
              box-shadow: 0 0 24px 4px oklch(0.60 0.26 10 / 0.3), inset 0 0 16px oklch(0.60 0.26 10 / 0.15);
              position: relative;
              display:flex; align-items:center; justify-content:center; gap:16px;
            ">
              <!-- Eyes -->
              <div style="width:14px;height:14px;border-radius:50%;background:oklch(0.87 0.20 88);box-shadow:0 0 12px 4px oklch(0.87 0.20 88 / 0.8);"></div>
              <div style="width:14px;height:14px;border-radius:50%;background:oklch(0.87 0.20 88);box-shadow:0 0 12px 4px oklch(0.87 0.20 88 / 0.8);"></div>
              <!-- Antenna -->
              <div style="position:absolute;top:-24px;left:50%;transform:translateX(-50%);width:3px;height:20px;background:oklch(0.60 0.26 10);border-radius:2px;">
                <div style="width:9px;height:9px;border-radius:50%;background:oklch(0.60 0.26 10);box-shadow:0 0 10px 3px oklch(0.60 0.26 10 / 0.9);position:absolute;top:-8px;left:-3px;"></div>
              </div>
            </div>
            <!-- Neck -->
            <div style="width:20px;height:10px;background:oklch(0.18 0.03 280);border-radius:3px;border:1px solid oklch(0.60 0.26 10 / 0.4);"></div>
            <!-- Torso -->
            <div style="
              width:120px;height:100px;border-radius:16px;
              background: linear-gradient(160deg, oklch(0.20 0.04 280), oklch(0.13 0.02 280));
              border: 1.5px solid oklch(0.87 0.20 88 / 0.5);
              box-shadow: 0 0 20px 3px oklch(0.87 0.20 88 / 0.25), inset 0 0 20px oklch(0.87 0.20 88 / 0.08);
              display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px;
            ">
              <!-- Chest panel -->
              <div style="width:70px;height:24px;border-radius:6px;background:oklch(0.12 0.02 280);border:1px solid oklch(0.60 0.26 10 / 0.5);display:flex;align-items:center;justify-content:center;gap:6px;">
                <div style="width:6px;height:6px;border-radius:50%;background:oklch(0.60 0.26 10);box-shadow:0 0 6px oklch(0.60 0.26 10);"></div>
                <div style="width:6px;height:6px;border-radius:50%;background:oklch(0.87 0.20 88);box-shadow:0 0 6px oklch(0.87 0.20 88);"></div>
                <div style="width:6px;height:6px;border-radius:50%;background:oklch(0.72 0.18 200);box-shadow:0 0 6px oklch(0.72 0.18 200);"></div>
              </div>
              <!-- LED strip -->
              <div style="width:80px;height:6px;border-radius:3px;background:linear-gradient(90deg, oklch(0.60 0.26 10), oklch(0.87 0.20 88));box-shadow:0 0 10px 2px oklch(0.87 0.20 88 / 0.6);"></div>
            </div>
            <!-- Hips -->
            <div style="width:90px;height:16px;border-radius:6px;background:oklch(0.16 0.03 280);border:1px solid oklch(0.60 0.26 10 / 0.35);"></div>
            <!-- Legs -->
            <div style="display:flex;gap:14px;">
              <div style="width:38px;height:60px;border-radius:8px 8px 10px 10px;background:linear-gradient(180deg, oklch(0.19 0.035 280), oklch(0.14 0.025 280));border:1.5px solid oklch(0.60 0.26 10 / 0.4);box-shadow:inset 0 0 10px oklch(0.60 0.26 10 / 0.1);"></div>
              <div style="width:38px;height:60px;border-radius:8px 8px 10px 10px;background:linear-gradient(180deg, oklch(0.19 0.035 280), oklch(0.14 0.025 280));border:1.5px solid oklch(0.60 0.26 10 / 0.4);box-shadow:inset 0 0 10px oklch(0.60 0.26 10 / 0.1);"></div>
            </div>
          </div>

          <!-- Top label -->
          <div style="
            position:absolute; top:16px; left:50%; transform:translateX(-50%);
            background: oklch(0.60 0.26 10 / 0.9);
            color: white; font-size:10px; font-weight:700; letter-spacing:0.15em;
            padding:4px 12px; border-radius:20px;
            font-family: var(--font-body);
            white-space: nowrap;
          ">LED MODEL X-7</div>

          <!-- Bottom label -->
          <div style="
            position:absolute; bottom:16px; left:50%; transform:translateX(-50%);
            font-size:11px; font-weight:600; letter-spacing:0.1em;
            color: oklch(0.87 0.20 88);
            font-family: var(--font-body);
            white-space: nowrap;
            text-shadow: 0 0 12px oklch(0.87 0.20 88 / 0.8);
          ">★ Available Now</div>
        </div>

        <!-- Floating tag 1 -->
        <div class="animate-slide-left delay-300 absolute top-8 -left-4 lg:left-0 rounded-xl px-4 py-3 text-sm font-semibold backdrop-blur-sm" style="
          background: oklch(0.12 0.025 280 / 0.9);
          border: 1px solid oklch(0.87 0.20 88 / 0.45);
          color: oklch(0.87 0.20 88);
          box-shadow: 0 0 20px oklch(0.87 0.20 88 / 0.2);
          font-family: var(--font-body);
        ">
          🎉 50+ Cities Covered
        </div>

        <!-- Floating tag 2 -->
        <div class="animate-slide-left delay-500 absolute bottom-16 -left-4 lg:left-4 rounded-xl px-4 py-3 text-sm font-semibold backdrop-blur-sm" style="
          background: oklch(0.12 0.025 280 / 0.9);
          border: 1px solid oklch(0.60 0.26 10 / 0.45);
          color: oklch(0.82 0.14 10);
          box-shadow: 0 0 20px oklch(0.60 0.26 10 / 0.2);
          font-family: var(--font-body);
        ">
          ⚡ Instant Quote
        </div>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background: linear-gradient(to bottom, transparent, oklch(0.09 0.02 280));"></div>
  </section>


  <!-- =====================================================================
       TICKER BAR
       ===================================================================== -->
  <div class="relative overflow-hidden py-4" style="background: oklch(0.12 0.025 280); border-top: 1px solid oklch(0.60 0.26 10 / 0.25); border-bottom: 1px solid oklch(0.60 0.26 10 / 0.25);">
    <div class="animate-ticker flex gap-12 whitespace-nowrap" style="width: max-content;">
      {[
        '🎂 Birthday Parties', '💒 Weddings', '🎊 Quinceañeras', '🏢 Corporate Events',
        '🎉 Sweet 16s', '🥂 Galas', '🎓 Grad Parties', '🎪 Brand Activations',
        '🎂 Birthday Parties', '💒 Weddings', '🎊 Quinceañeras', '🏢 Corporate Events',
        '🎉 Sweet 16s', '🥂 Galas', '🎓 Grad Parties', '🎪 Brand Activations',
      ].map((item) => (
        <span class="text-sm font-semibold tracking-wide" style="color: oklch(0.65 0.01 280); font-family: var(--font-body);">
          {item}
        </span>
      ))}
    </div>
  </div>


  <!-- =====================================================================
       SOCIAL PROOF STATS
       ===================================================================== -->
  <section class="py-20 md:py-24" style="background: oklch(0.09 0.02 280);">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
        {[
          { number: '500+', label: 'Events Electrified', color: 'oklch(0.60 0.26 10)' },
          { number: '50+',  label: 'Cities Covered',    color: 'oklch(0.87 0.20 88)' },
          { number: '4.9★', label: 'Average Rating',    color: 'oklch(0.72 0.18 200)' },
          { number: '24h',  label: 'Booking Response',  color: 'oklch(0.60 0.26 10)' },
        ].map((stat) => (
          <div class="text-center group">
            <p class="font-display leading-none" style={`font-size: clamp(2.4rem, 5vw, 3.5rem); color: ${stat.color}; text-shadow: 0 0 32px ${stat.color.replace(')', ' / 0.55)')};`}>
              {stat.number}
            </p>
            <p class="mt-3 text-sm font-medium tracking-wide uppercase" style="color: oklch(0.55 0.01 280); font-family: var(--font-body);">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Beam divider -->
  <div class="beam-divider mx-auto max-w-4xl"></div>


  <!-- =====================================================================
       HOW IT WORKS
       ===================================================================== -->
  <section id="how-it-works" class="py-24 md:py-32" style="background: oklch(0.09 0.02 280);">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-16">
        <p class="text-xs font-bold tracking-[0.25em] uppercase mb-4" style="color: oklch(0.87 0.20 88);">The Process</p>
        <h2 class="font-display leading-tight" style="font-size: clamp(2rem, 4.5vw, 3.25rem); color: oklch(0.95 0.005 280);">
          Robot at your party in<br><span class="gradient-text">3 easy steps</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Connector line (desktop) -->
        <div class="hidden md:block absolute top-10 left-[22%] right-[22%] h-px" style="background: linear-gradient(90deg, oklch(0.60 0.26 10 / 0.5), oklch(0.87 0.20 88 / 0.5));"></div>

        {[
          {
            step: '01',
            title: 'Pick Your Robot',
            desc: 'Choose from our LED Dancer, Humanoid Host, or Premium Show duo. Get an instant transparent quote — no calls required.',
            icon: '🤖',
            color: 'oklch(0.60 0.26 10)',
          },
          {
            step: '02',
            title: 'Book in Minutes',
            desc: 'Lock in your date with a simple online booking. We confirm within 2 hours and handle all the logistics for your event.',
            icon: '📅',
            color: 'oklch(0.87 0.20 88)',
          },
          {
            step: '03',
            title: 'Watch Jaws Drop',
            desc: 'Our team arrives early, sets up, and our robot steals the show. Guests will be posting clips for weeks.',
            icon: '🎉',
            color: 'oklch(0.72 0.18 200)',
          },
        ].map((item, i) => (
          <div class="relative rounded-2xl p-8" style={`
            background: oklch(0.11 0.02 280);
            border: 1px solid ${item.color.replace(')', ' / 0.3)')};
          `}>
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl mb-6" style={`
              background: ${item.color.replace(')', ' / 0.12)')};
              border: 1px solid ${item.color.replace(')', ' / 0.4)')};
              box-shadow: 0 0 20px ${item.color.replace(')', ' / 0.2)')};
            `}>
              {item.icon}
            </div>
            <div class="absolute top-8 right-8 font-display text-5xl leading-none font-black opacity-10" style={`color: ${item.color};`}>
              {item.step}
            </div>
            <h3 class="font-display text-xl mb-3" style={`color: ${item.color};`}>{item.title}</h3>
            <p class="text-base leading-relaxed" style="color: oklch(0.62 0.01 280); font-family: var(--font-body);">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Beam divider -->
  <div class="beam-divider mx-auto max-w-4xl"></div>


  <!-- =====================================================================
       ROBOT PACKAGES (Product Feature Deep-Dives)
       ===================================================================== -->
  <section id="packages" class="py-24 md:py-32 relative overflow-hidden" style="background: oklch(0.09 0.02 280);">
    <!-- Background glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div style="position:absolute; width:60vw; height:60vw; top:20%; left:50%; transform:translateX(-50%); background:radial-gradient(ellipse at center, oklch(0.60 0.26 10 / 0.07) 0%, transparent 70%); filter:blur(20px);"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-16">
        <p class="text-xs font-bold tracking-[0.25em] uppercase mb-4" style="color: oklch(0.87 0.20 88);">Robot Packages</p>
        <h2 class="font-display leading-tight" style="font-size: clamp(2rem, 4.5vw, 3.25rem); color: oklch(0.95 0.005 280);">
          Find your perfect<br><span class="gradient-text">party robot</span>
        </h2>
        <p class="mt-5 text-lg max-w-xl mx-auto" style="color: oklch(0.62 0.01 280); font-family: var(--font-body);">
          Every package includes setup, operation by our trained technician, and social media-ready moments.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">

        <!-- Package 1: LED Dancer -->
        <div class="rounded-2xl overflow-hidden flex flex-col group transition-transform duration-300 hover:-translate-y-2" style="
          background: oklch(0.11 0.025 280);
          border: 1px solid oklch(0.16 0.025 280);
          box-shadow: 0 4px 32px oklch(0.09 0.02 280 / 0.5);
        ">
          <!-- Top accent bar -->
          <div style="height:4px; background: linear-gradient(90deg, oklch(0.60 0.26 10), oklch(0.82 0.14 10 / 0.5));"></div>
          <div class="p-8 flex flex-col flex-1">
            <div class="text-4xl mb-4">🕺</div>
            <h3 class="font-display text-2xl mb-2" style="color: oklch(0.82 0.14 10);">LED Dancer</h3>
            <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: oklch(0.55 0.01 280); font-family: var(--font-body);">Best for Birthdays & Quinceañeras</p>
            <p class="text-base leading-relaxed mb-6 flex-1" style="color: oklch(0.65 0.01 280); font-family: var(--font-body);">
              A fully-costumed LED suit robot that dances with guests, poses for photos, and lights up your dance floor. Synchronized to your playlist.
            </p>
            <ul class="space-y-2 mb-8" style="font-family: var(--font-body);">
              {['3-hour performance window', 'Unlimited photo ops', 'Custom LED color matching', 'Pro technician on-site'].map(f => (
                <li class="flex items-center gap-2 text-sm" style="color: oklch(0.70 0.01 280);">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="14" height="14" style="color: oklch(0.60 0.26 10); flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <div class="mt-auto">
              <p class="text-3xl font-display mb-1" style="color: oklch(0.95 0.005 280);">From <span style="color: oklch(0.82 0.14 10);">$499</span></p>
              <p class="text-xs mb-5" style="color: oklch(0.50 0.01 280); font-family: var(--font-body);">3-hour package · travel fees may apply</p>
